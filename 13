import tkinter as tk  
root = tk.Tk()
root.title("Окно")
root.geometry("500x500")

label = tk.Label(root, text="notes")
label.pack()

entry = tk.Entry(root, width=40)
entry.pack()

listbox = tk.Listbox(root,width=40)
listbox.pack()

def add_note():
    text = entry.get()
    entry.delete(0, tk.END)
    listbox.insert(tk.END, text)

button = tk.Button(root, text="add", command=add_note,height=2, width=20,  bg="blue", fg="white")
button.pack()


root.mainloop()
